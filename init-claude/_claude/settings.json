{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissionMode": "allowEdits",
  "language": "ja",

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(cat*)",
      "Bash(echo*)"
    ],
    "deny": []
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PreToolUse/safety-check.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/PreToolUse/rtk-wrap.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/Stop/git-status-check.sh"
          }
        ]
      }
    ]
  },

  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
