{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/user/projects"
      ]
    },
    "figma": {
      "url": "https://mcp.figma.com/mcp"
    },
    "rtk": {
      "command": "npx",
      "args": ["-y", "rtk-mcp"],
      "env": {
        "RTK_TELEMETRY_DISABLED": "1"
      }
    }
  }
}
